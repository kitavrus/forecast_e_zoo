# =============================================================================
# e_zoo — переменные окружения для docker-compose и локального запуска.
# Скопируй в .env: `cp .env.example .env`
# =============================================================================

# --- Postgres credentials (используется postgres init) ---
POSTGRES_USER=adapter
POSTGRES_PASSWORD=adapter
POSTGRES_DB=source_adapter

# --- e_zoo_app service-роль (создаётся init-скриптом) ---
EZOO_APP_PASSWORD=ezoo_app_dev

# --- Общий DB DSN для всех 7 сервисов ---
# Внутри docker network: host=postgres. Локально: host=localhost.
DB_DSN=postgres://e_zoo_app:ezoo_app_dev@postgres:5432/source_adapter?sslmode=disable&pool_max_conns=20
DB_MAX_CONNS=20
DB_MIN_CONNS=2

# --- Logging / env ---
LOG_LEVEL=INFO
APP_ENV=dev

# --- JWT (общий — все сервисы валидируют тем же ключом) ---
JWT_ALG=HS256
JWT_SECRET=dev-secret-change-in-prod
JWT_PUBLIC_KEY_PATH=
JWT_ADMIN_ROLE=admin-cli
JWT_READ_ROLES=x-flow-etl,it-read

# =============================================================================
# Per-service ENV (HTTP_ADDR + scheduler).
# =============================================================================

# --- 1) source-adapter (M1, port 8080) ---
HTTP_ADDR=:8080
SOURCE_ADAPTER_CRON_SCHEDULE=0 2 * * *
SOURCE_ADAPTER_TZ=Europe/Kyiv
SOURCE_ADAPTER_STALE_LOAD_TIMEOUT=1h
QUALITY_THRESHOLD_PCT=1.0
EXPORTS_BASE_DIR=/var/exports
EXPORTS_RETENTION=24h
EXPORTS_INLINE_MAX_MB=50
AUDIT_RETENTION=2160h
REJECT_LOG_RETENTION=2160h
VALIDATION_RULES_PATH=/etc/source-adapter/validation_rules.yaml
MASTER_TRACKED_FIELDS_PATH=/etc/source-adapter/master_tracked_fields.yaml
PROMETHEUS_PATH=/metrics

# ERP backend (источник)
ERP_BASE_URL=http://mock-erp:8090
ERP_AUTH_MODE=api_key
ERP_API_KEY=test-api-key
ERP_OAUTH_TOKEN_URL=
ERP_OAUTH_CLIENT_ID=
ERP_OAUTH_CLIENT_SECRET=
ERP_MTLS_CERT_PATH=
ERP_MTLS_KEY_PATH=
ERP_HTTP_TIMEOUT=30s
ERP_RETRY_MAX=3
ERP_RETRY_BACKOFF_CAP=30s

# --- Mock ERP ---
MOCK_ERP_API_KEY=test-api-key
# Scale knobs. Defaults below match the realistic E2E profile.
# Legacy "Large" scale was 1000/30/365/50 but produced ~0 replenishment_plans
# (demand density too low). 200/10/180/20 + tx/init-stock tuning yields
# reproducible 8/8 stages with non-empty plans in ~5–15 minutes total.
SEED_PRODUCTS=200
SEED_LOCATIONS=10
SEED_DAYS=180
SEED_SUPPLIERS=20

# --- Seeder tuning (realistic E2E) ---
# Mean number of receipts per (product, location) per day. Drives demand
# density. lambda is base_daily_demand × (this / 5). Recommended: 5.
SEED_TRANSACTIONS_PER_PAIR_PER_DAY=5
# Initial qty_on_hand = base_daily_demand × N days. Lower N → more pressure
# on forecast → larger replenishment_plans. Recommended: 14.
SEED_INITIAL_STOCK_DAYS_OF_DEMAND=14
# % of locations covered by an order_rule (location-scope). Recommended: 100.
SEED_ORDER_RULE_COVERAGE_PCT=100
# % of products with at least one supply_spec (supplier link). Required for
# ETL supplier_fallback CTE — without it forecast cannot build PO. Recommended: 100.
SEED_SUPPLY_SPEC_COVERAGE_PCT=100
# supply_spec.lead_time_days bounds (random per row). Recommended: 7..21.
SEED_LEAD_TIME_MIN_DAYS=7
SEED_LEAD_TIME_MAX_DAYS=21
# base_daily_demand bounds per (product, location) pair. Recommended: 1..20.
SEED_DAILY_DEMAND_MIN=1
SEED_DAILY_DEMAND_MAX=20

# --- 2) etl (M2, port 8081) ---
ETL_DSN=postgres://e_zoo_app:ezoo_app_dev@postgres:5432/source_adapter?sslmode=disable&pool_max_conns=20
ETL_DB_MAX_CONNS=20
ETL_DB_MIN_CONNS=2
ETL_HTTP_PORT=8081
ETL_SOURCE_ADAPTER_URL=http://source-adapter:8080
ETL_HTTP_TIMEOUT=30s
ETL_HTTP_RETRY_MAX=3
ETL_RETRY_BACKOFF_CAP=30s
ETL_JWT_SIGNING_KEY=dev-secret-change-in-prod
ETL_JWT_ROLE=x-flow-etl
ETL_ADMIN_JWT_SECRET=dev-secret-change-in-prod
ETL_CRON_SCHEDULE=30 2 * * *
ETL_CRON_TIMEZONE=Europe/Kyiv
ETL_VALIDATION_RULES_PATH=/app/configs/etl_validation_rules.yaml
ETL_QUALITY_THRESHOLD=0.01
ETL_LOG_LEVEL=info
ETL_ENV=development

# --- 3) data-marts (M3, port 8082) ---
MARTS_HTTP_ADDR=:8082

# --- 4) kpi (M4, port 8083) ---
KPI_HTTP_ADDR=:8083
KPI_CRON_SCHEDULE=0 4 * * *
KPI_CRON_TZ=Europe/Kyiv

# --- 5) forecast (M5, port 8084) ---
FORECAST_HTTP_ADDR=:8084
FORECAST_CRON_SCHEDULE=0 5 * * *
FORECAST_CRON_TZ=Europe/Kyiv
FORECAST_HORIZON_DAYS=60

# --- 6) order-builder (M6, port 8086 — 8085 пропущен) ---
ORDER_BUILDER_HTTP_ADDR=:8086
ORDER_BUILDER_CRON_SCHEDULE=0 6 * * *
ORDER_BUILDER_CRON_TZ=Europe/Kyiv
ORDER_BUILDER_MAX_PLANS=500

# --- 7) channel-router (M7, port 8087) ---
CHANNEL_ROUTING_HTTP_ADDR=:8087
CHANNEL_ROUTING_CRON_SCHEDULE=30 6 * * *
CHANNEL_ROUTING_CRON_TZ=Europe/Kyiv
CHANNEL_ROUTING_MAX_POS=500
CHANNEL_ROUTING_HTTP_TIMEOUT_SEC=30

# --- OpenTelemetry (общий для всех) ---
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_TRACES_SAMPLER_ARG=1.0
